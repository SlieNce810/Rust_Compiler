func int main() {
    int interval_ms;
    int key1_state;
    int key2_state;
    int pulse;

    pulse = 1;
    interval_ms = 220;

    key1_state = key1_read();
    key2_state = key2_read();

    if (key1_state > 0) {
        interval_ms = 80;
    } else {
        if (key2_state > 0) {
            interval_ms = 520;
        }
    }

    sleep_ms(interval_ms);
    return pulse;
}
